/**
 * Global styles
 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: #1a1a2e;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.text-muted {
  color: #999;
  font-size: 24rpx;
}

.text-center {
  text-align: center;
}
